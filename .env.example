# Local stdio MCP mode.
VESSEL_MCP_TRANSPORT=stdio

# Streamable HTTP MCP mode for remote clients.
# VESSEL_MCP_TRANSPORT=http
# VESSEL_MCP_HTTP_HOST=127.0.0.1
# VESSEL_MCP_HTTP_PORT=3000
#
# Optional bearer-token auth for /mcp. /health remains public and must not
# expose this value.
# VESSEL_MCP_AUTH_TOKEN=

# Future live-provider credentials belong in local ignored env files or secret
# stores only. Do not commit API keys, cookies, bearer tokens, or HAR captures.
# AISSTREAM_API_KEY=
# AISHUB_USERNAME=
# MYSHIPTRACKING_API_KEY=
